rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /contacts/{document} {
      allow create: if true; // anyone can submit contact form
      allow read, update, delete: if request.auth != null; // only logged-in users can view
    }
    match /{document=**} {
      allow read, write: if false; // deny everything else
    }
  }
}
